--- !u!114 &840816614
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 840816613}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff41284d8a1c8b0498218d8f11cc6984, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  startingNode:
    dialogue:
    - text: Mam, I don't feel well.
      faceToShow: {fileID: 464262689}
    - text: I have a headache.
      faceToShow: {fileID: 464262689}
    - text: Can you get me something to help please?
      faceToShow: {fileID: 1364797963}
    choices:
    - choiceText: Paracetamol
      nextNode:
        dialogue:
        - text: That's good.
          faceToShow: {fileID: 1284924271}
        - text: And some water as well please.
          faceToShow: {fileID: 1284924271}
        choices: []
    - choiceText: Flat 7-Up
      nextNode:
        dialogue:
        - text: I don't think that'll help
          faceToShow: {fileID: 37669064}
        choices:
        - choiceText: Sure it will!
          nextNode:
            dialogue:
            - text: No I think paracetamol and water will do.
              faceToShow: {fileID: 1285793367}
            choices: []
        - choiceText: OK, something else then
          nextNode:
            dialogue:
            - text: Yes, paracetamol and some water please
              faceToShow: {fileID: 1284924271}
            choices: []
