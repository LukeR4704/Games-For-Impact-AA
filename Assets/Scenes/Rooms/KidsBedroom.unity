MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1997395444}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff41284d8a1c8b0498218d8f11cc6984, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  startingNode:
    dialogue:
    - text: Morning.
      faceToShow: {fileID: 464262689}
    choices:
    - choiceText: You OK?
      nextNode:
        dialogue:
        - text: No. I didn't sleep great last night.
          faceToShow: {fileID: 1364797963}
        - text: I'm cold.
          faceToShow: {fileID: 1364797963}
        choices:
        - choiceText: You also stink
          nextNode:
            dialogue:
            - text: Really?
              faceToShow: {fileID: 37669064}
            - text: Fine, I'll go shower.
              faceToShow: {fileID: 1285793367}
            - text: I don't have a towel though...
              faceToShow: {fileID: 1364797963}
            choices: []
        - choiceText: What's that smell?
          nextNode:
            dialogue:
            - text: Probably me.
              faceToShow: {fileID: 464262689}
            - text: I'll go shower.
              faceToShow: {fileID: 464262689}
            - text: I need a towel though...
              faceToShow: {fileID: 1364797963}
            choices: []
    - choiceText: You stink
      nextNode:
        dialogue:
        - text: Harsh.
          faceToShow: {fileID: 37669064}
        - text: But fair. I'll go shower. I need a towel though.
          faceToShow: {fileID: 1364797963}
        - text: I was also cold last night. Could you get me a blanket also please?
          faceToShow: {fileID: 1364797963}
        choices:
        - choiceText: Of course
          nextNode:
            dialogue:
            - text: Thanks, Mam. You're the best.
              faceToShow: {fileID: 1284924271}
            choices: []
        - choiceText: That's a lot
          nextNode:
            dialogue:
            - text: I'm sorry. I appreciate all you do for me...
              faceToShow: {fileID: 464262689}
            choices: []
