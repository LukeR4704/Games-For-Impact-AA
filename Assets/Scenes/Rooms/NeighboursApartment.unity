MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 180207488}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff41284d8a1c8b0498218d8f11cc6984, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  startingNode:
    dialogue:
    - Hi, miss!
    choices:
    - choiceText: Hello
      nextNode:
        dialogue:
        - Can I talk to you?
        choices:
        - choiceText: Sure
          nextNode:
            dialogue:
            - I don't like school.
            choices:
            - choiceText: Why not?
              nextNode:
                dialogue:
                - Homework's the worst.
                - That's why I'm talking to you.
                - To avoid it.
                choices: []
            - choiceText: Same
              nextNode:
                dialogue:
                - I don't think you should be saying that.
                - Shouldn't you be telling me positive stuff about school?
                choices: []
        - choiceText: About what?
          nextNode:
            dialogue:
            - Anything, I guess.
            - I just don't want to do my homework.
            choices: []
    - choiceText: Where are your parents?
      nextNode:
        dialogue:
        - Well, my Mom left us after I was born.
        - And my Dad doesn't talk to me much...
        choices:
        - choiceText: Oh...
          nextNode:
            dialogue:
            - Yeah...
            - ...
            choices: []
        - choiceText: I'll talk to you
          nextNode:
            dialogue:
            - Really?
            - Thank you. You're really nice.
            choices: []
