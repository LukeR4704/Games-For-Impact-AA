  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  startingNode:
    dialogue:
    - text: Ahhhh!
      faceToShow: {fileID: 37669064}
    - text: Mam, I burnt myself on the candle.
      faceToShow: {fileID: 464262689}
    choices:
    - choiceText: Told ya
      nextNode:
        dialogue:
        - text: I know you told me not to go near it I'm sorry.
          faceToShow: {fileID: 464262689}
        - text: Please help.
          faceToShow: {fileID: 464262689}
        choices:
        - choiceText: First Aid Kit
          nextNode:
            dialogue:
            - text: Yes, thank you.
              faceToShow: {fileID: 1284924271}
            choices: []
        - choiceText: Too bad
          nextNode:
            dialogue:
            - text: Please get me a bandage. It hurts.
              faceToShow: {fileID: 1285793367}
            choices: []
    - choiceText: Are you OK?
      nextNode:
        dialogue:
        - text: No, it hurts.
          faceToShow: {fileID: 464262689}
        - text: Please get me something to help.
          faceToShow: {fileID: 464262689}
        choices: []
